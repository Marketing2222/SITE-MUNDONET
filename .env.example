# =============================================================
# Variáveis de Ambiente – Site Mundonet
# Copie este arquivo para .env e preencha os valores
# =============================================================

# ── Backend ──────────────────────────────────────────────────
# Porta do servidor Express
PORT=3001

# URL pública do site (usada para montar URLs de upload de imagens)
# Em produção: https://mundonet.seudominio.com.br
PUBLIC_URL=http://localhost:3001

# Origens permitidas no CORS (separadas por vírgula)
# Em produção: https://mundonet.seudominio.com.br
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Segredo JWT (TROQUE para um valor aleatório longo em produção!)
JWT_SECRET=troque-este-valor-por-algo-seguro-em-producao

# ── Frontend (Build-time – Vite) ──────────────────────────────
# URL base da API consumida pelo frontend React
# ATENÇÃO: esta variável é embutida no build estático do Vite
# Em produção: https://mundonet.seudominio.com.br
# Se o frontend e backend estiverem no mesmo domínio/porta, deixe vazio:
VITE_API_URL=
